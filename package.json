  "private": true,
  "homepage": "https://alysoun.github.io/euchre",
  "dependencies": {
    "@playfield/core": "file:./playfield/packages/core",
    "framer-motion": "^12.40.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-draggable": "^4.4.6",
    "styled-components": "^6.1.13"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.9.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.2.1",
    "adm-zip": "^0.5.17",
    "gh-pages": "^6.2.0",
    "typescript": "^4.9.5",
